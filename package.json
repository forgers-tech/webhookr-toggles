{
  "name": "webhookr-toggles",
  "version": "0.0.1",
  "description": "Declarative, Git-sourced management of Webhookr Unleash feature toggles.",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24",
    "npm": ">=10"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"scripts/**/*.ts\" \"test/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.ts\" \"test/**/*.ts\"",
    "test": "node --test \"test/**/*.test.ts\"",
    "validate": "node src/validate.ts",
    "apply": "node src/apply.ts",
    "drift": "node src/drift.ts",
    "set-state": "node scripts/set-state.ts"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "26.1.1",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "prettier": "3.9.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0"
  }
}
