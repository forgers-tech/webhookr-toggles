# Local configuration for running apply/drift against an Unleash instance.
# Copy to .env and fill in. Never commit real tokens.

# Unleash admin API base URL (includes the /api suffix).
UNLEASH_URL=http://localhost:4242/api

# Unleash ADMIN API token (client/frontend tokens cannot create or flip flags).
UNLEASH_API_TOKEN=

# Logical environment key from config/environments.yaml (prd | qa).
# apply/drift read the desired state from toggles.yaml[states][TARGET_ENV] and
# write to the mapped Unleash environment/project declared in that file.
TARGET_ENV=prd
